# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
ENV=development   # development | staging | production

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://salvia:salvia@localhost:5432/salvia?sslmode=disable

# ── Security ──────────────────────────────────────────────────────────────────
# 32-byte base64-encoded AES-256-GCM key for PII field encryption.
# Generate with: make gen-key
ENCRYPTION_KEY=REPLACE_WITH_OUTPUT_OF_make_gen-key

# HS256 secret for signing JWTs. Must be at least 32 bytes (256 bits).
# Generate with: make gen-jwt-secret
JWT_SECRET=REPLACE_WITH_OUTPUT_OF_make_gen-jwt-secret

# Access token lifetime (e.g. 15m, 1h, 24h).
JWT_ACCESS_TTL=15m

# Refresh token lifetime (e.g. 720h = 30 days).
JWT_REFRESH_TTL=720h

# Magic link token lifetime.
MAGIC_LINK_TTL=15m

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
# In dev: point at Mailpit (docker compose up). Web UI at http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@salvia.app
SMTP_FROM_NAME=Salvia

# ── Storage (S3-compatible) ───────────────────────────────────────────────────
# In dev: point at MinIO (docker compose up). Console at http://localhost:9001
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=salvia-audio
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_REGION=ap-southeast-2
# Set to true when using MinIO or other S3-compatible services (not AWS S3 itself).
STORAGE_USE_PATH_STYLE=true

# ── Transcription provider ────────────────────────────────────────────────────
# `deepgram` (prod default) — Nova-3 Medical, word-level confidence, BAA available.
# `gemini` (dev/staging) — uses GEMINI_API_KEY, no word-level confidence.
TRANSCRIPTION_PROVIDER=deepgram
# Required when TRANSCRIPTION_PROVIDER=deepgram. Leave empty to skip transcription.
# Get one at https://console.deepgram.com.
DEEPGRAM_API_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────────
# Used for magic link and invite URLs in emails.
APP_URL=http://localhost:3000
# Allowed CORS origins (comma-separated). :3000 = Salvia app (Flutter web),
# :5173 = /mel marketing site (Vite dev server).
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# ── /mel handoff (marketing site → signed-in app) ────────────────────────────
# HS256 shared secret for the short-lived JWT minted by /mel and consumed by
# /api/v1/auth/handoff. Must match VITE_MEL_HANDOFF_JWT_SECRET (if the /mel
# site signs its own tokens) or be used by /api/v1/auth/signup/start when the
# /mel site delegates minting. Rotate by rolling on both sides in lockstep.
# Generate with: make gen-jwt-secret
MEL_HANDOFF_JWT_SECRET=e632eccd210aa21a40d5ea744dd12d684de10e02ed3edb31f5abd0c510c545e0fcd2a8d121a1725e816b614fbfd9605742fa571ae6870515f49cff519202da2d

# ── Stripe billing ────────────────────────────────────────────────────────────
# Signing secret for /api/v1/billing/webhook — from the Stripe dashboard
# (Developers → Webhooks → Signing secret). When unset the webhook route is
# not mounted and billing webhooks are disabled.
STRIPE_WEBHOOK_SECRET=

# Secret key (sk_test_… / sk_live_…) used to open Stripe customer-portal
# sessions from /api/v1/billing/portal. When unset the portal endpoint 400s
# with "billing portal unavailable".
STRIPE_API_KEY=

# price_id → plan_code mapping. Comma-separated pairs.
# Example: price_abc=paws_pro_monthly,price_def=paws_pro_annual
STRIPE_PRICE_MAP=

# ── Note-cap CS escalation ────────────────────────────────────────────────────
# Destination for the 110%-of-cap CS alert (pricing-model-v3 §7). When unset,
# the CS branch of the cascade is silently disabled — clinic-side warnings
# at 80% still fire. Point at your shared ops inbox in prod.
OPS_ALERT_EMAIL=ops@salvia.local