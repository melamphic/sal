<section class="page">
  {{ template "doc-header" headerInfo
      "Resident Trend Report"
      (printf "Pain Score · %s" .PeriodLabel)
      (printf "Generated %s" .GeneratedOn) }}

  <div class="section">
    <span class="section__eyebrow">Resident</span>
    <h1 class="section__title">{{ .SubjectName }} · Pain Trend &amp; Analgesia Review</h1>
  </div>

  <div class="meta-grid meta-grid--3">
    <div class="meta"><span class="meta__label">Resident</span><span class="meta__value">{{ .SubjectName }}</span></div>
    <div class="meta"><span class="meta__label">Room / wing</span><span class="meta__value">{{ .SubjectRoom }}</span></div>
    <div class="meta"><span class="meta__label">Care category</span><span class="meta__value">{{ .SubjectMeta }}</span></div>
    <div class="meta"><span class="meta__label">Period</span><span class="meta__value">{{ .PeriodLabel }} · {{ .WindowDays }} days</span></div>
    <div class="meta"><span class="meta__label">Assessments</span><span class="meta__value">{{ .Assessments }}</span></div>
    <div class="meta"><span class="meta__label">Scales used</span><span class="meta__value">{{ .ScalesUsed }}</span></div>
  </div>

  <div class="kpi-grid">
    <div class="kpi">
      <span class="kpi__label">Mean Score</span>
      <span class="kpi__value">{{ printf "%.1f" .MeanScore }}</span>
      <span class="kpi__hint">10-pt NRS-equivalent</span>
    </div>
    <div class="kpi kpi--warn">
      <span class="kpi__label">Peak Score</span>
      <span class="kpi__value" style="color: var(--salvia-warning);">{{ .PeakScore }}</span>
      <span class="kpi__hint">{{ .PeakWhen }}</span>
    </div>
    <div class="kpi kpi--accent">
      <span class="kpi__label">% Days with ≥1 PRN</span>
      <span class="kpi__value">{{ .PRNDaysPct }}%</span>
      <span class="kpi__hint">{{ .PRNDaysCount }} days</span>
    </div>
    <div class="kpi">
      <span class="kpi__label">Witnessed Assessments</span>
      <span class="kpi__value">{{ .WitnessedHigh }}</span>
      <span class="kpi__hint">All score ≥ 4</span>
    </div>
  </div>

  <div class="chart-host">
    <div class="chart-host__title" style="font-size: 9pt; font-weight: 800; color: var(--salvia-text-emphasis); margin-bottom: 4px;">
      Daily pain score · {{ .PeriodLabel }}
    </div>
    <div class="chart-host__subtitle" style="font-size: 7.5pt; color: var(--salvia-muted); margin-bottom: 8px;">
      PainAD &amp; NRS normalised to 0-10. Red band = ≥7 (severe). Amber band = 4-6 (moderate).
    </div>
    <div style="position: relative; width: 100%; height: 220px;">
      <canvas id="painLine"></canvas>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin: 14px 0;">
    <div class="chart-host">
      <div class="chart-host__title" style="font-size: 9pt; font-weight: 800; margin-bottom: 4px;">Score distribution</div>
      <div class="chart-host__subtitle" style="font-size: 7.5pt; color: var(--salvia-muted); margin-bottom: 8px;">
        {{ .Assessments }} assessments, banded by severity
      </div>
      <div style="position: relative; width: 100%; height: 180px;">
        <canvas id="painDist"></canvas>
      </div>
    </div>
    <div class="chart-host">
      <div class="chart-host__title" style="font-size: 9pt; font-weight: 800; margin-bottom: 4px;">PRN analgesia events</div>
      <div class="chart-host__subtitle" style="font-size: 7.5pt; color: var(--salvia-muted); margin-bottom: 8px;">
        Paracetamol + oramorph by week
      </div>
      <div style="position: relative; width: 100%; height: 180px;">
        <canvas id="prnBar"></canvas>
      </div>
    </div>
  </div>

  {{- if .HighScores }}
  <div class="section">
    <span class="section__eyebrow">Highest scores</span>
    <h2 class="section__title">Assessments scoring ≥ 5/10</h2>
  </div>

  <table class="tbl">
    <thead>
      <tr>
        <th style="width: 90px">When</th>
        <th class="center" style="width: 60px">Score</th>
        <th class="center" style="width: 80px">Scale</th>
        <th>Assessor / context</th>
        <th class="center" style="width: 70px">Witness</th>
        <th>PRN given</th>
      </tr>
    </thead>
    <tbody>
      {{- range .HighScores }}
      <tr>
        <td>{{ .WhenPretty }}</td>
        <td class="center"><span class="pill pill--{{ .ScoreTone }}">{{ .Score }}</span></td>
        <td class="center">{{ .Scale }}</td>
        <td>{{ .Context }}</td>
        <td class="center">{{ .Witness }}</td>
        <td>{{ .PRNGiven }}</td>
      </tr>
      {{- end }}
    </tbody>
  </table>
  {{- end }}

  <div class="signature-grid">
    <div class="signature">
      <div class="signature__role">Generated by</div>
      <div class="signature__name">{{ .GeneratedBy }}</div>
      <div class="signature__meta"><span></span><span>{{ .GeneratedOn }}</span></div>
    </div>
    <div class="signature">
      <div class="signature__role">Clinical review</div>
      <div class="signature__name">— pending —</div>
      <div class="signature__meta"><span></span><span>—</span></div>
    </div>
  </div>

  {{ template "doc-footer" footerInfo
      (printf "Pain Trend · %s · %s" .SubjectName .PeriodLabel)
      "Page 1 of 1"
      (printf "Generated %s" .GeneratedOn) }}
</section>

<script>
  (function() {
    var dailyLabels = {{ jsonArr .DailyLabels }};
    var dailyScores = {{ jsonArr .DailyScores }};
    var distLabels  = {{ jsonArr .DistLabels }};
    var distCounts  = {{ jsonArr .DistCounts }};
    var weekLabels  = {{ jsonArr .WeekLabels }};
    var prnPara     = {{ jsonArr .PRNParacetamol }};
    var prnOra      = {{ jsonArr .PRNOramorph }};

    var done = 0;
    function maybeReady() { done += 1; if (done >= 3) { window.__chartsReady = true; } }

    new Chart(document.getElementById('painLine').getContext('2d'), {
      type: 'line',
      data: {
        labels: dailyLabels,
        datasets: [{
          label: 'Pain score (0-10)',
          data: dailyScores,
          borderColor: '#0e7c66',
          backgroundColor: 'rgba(14,124,102,0.10)',
          borderWidth: 2, tension: 0.35, pointRadius: 3,
          pointBackgroundColor: '#0e7c66', fill: true,
        }]
      },
      options: {
        animation: { onComplete: maybeReady, duration: 0 },
        responsive: true, maintainAspectRatio: false,
        scales: {
          y: {
            min: 0, max: 10, ticks: { stepSize: 2, font: { size: 9 } },
            grid: { color: function(ctx) { return ctx.tick.value >= 7 ? 'rgba(185,28,28,0.18)' : ctx.tick.value >= 4 ? 'rgba(194,65,12,0.10)' : 'rgba(15,23,42,0.05)'; } }
          },
          x: { ticks: { font: { size: 8 }, maxRotation: 0, autoSkip: true, maxTicksLimit: 10 } }
        },
        plugins: { legend: { display: false } }
      }
    });

    new Chart(document.getElementById('painDist').getContext('2d'), {
      type: 'bar',
      data: {
        labels: distLabels,
        datasets: [{ data: distCounts, backgroundColor: ['#86efac','#bef264','#fdba74','#fca5a5'], borderRadius: 4 }]
      },
      options: {
        animation: { onComplete: maybeReady, duration: 0 },
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true, ticks: { font: { size: 9 } } }, x: { ticks: { font: { size: 9 } } } }
      }
    });

    new Chart(document.getElementById('prnBar').getContext('2d'), {
      type: 'bar',
      data: {
        labels: weekLabels,
        datasets: [
          { label: 'Paracetamol', data: prnPara, backgroundColor: '#0e7c66', borderRadius: 4 },
          { label: 'Oramorph',    data: prnOra,  backgroundColor: '#c2410c', borderRadius: 4 }
        ]
      },
      options: {
        animation: { onComplete: maybeReady, duration: 0 },
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: { font: { size: 9 } } } },
        scales: {
          y: { beginAtZero: true, stacked: true, ticks: { font: { size: 9 } } },
          x: { stacked: true, ticks: { font: { size: 9 } } }
        }
      }
    });
  })();
</script>
