      {"position": 9, "title": "Restoration placed", "type": "text"},
      {"position": 10, "title": "Post-op instructions given", "type": "button_group", "config": {"options": [{"label": "Verbal", "value": "verbal"}, {"label": "Written", "value": "written"}, {"label": "Both", "value": "both"}]}, "required": true}
    ]
