      {"position": 7, "title": "Treatment items / codes", "type": "long_text", "ai_prompt": "List planned items with their treatment codes (CDT in US, ADA Schedule in AU, etc.)."},
      {"position": 8, "title": "Recall interval", "type": "select", "config": {"options": [{"label": "3 months", "value": "3m"}, {"label": "6 months", "value": "6m"}, {"label": "12 months", "value": "12m"}]}}
    ]
  },
